#!/usr/bin/env bash

# ==============================================================================
# dtf - A wrapper script for managing Nix-based dotfiles
#
# ==============================================================================

# Check for -e flag for debug mode
if [[ "$1" == "-e" ]]; then
    set -ex
    shift
else
    set -e
fi


USER_SECRETS="${HOME}/.config/dotfiles/secrets.nix"
SYSTEM_SECRETS="/etc/dotfiles/secrets.nix"
if [ -f "$USER_SECRETS" ]; then
    DOTFILES_DIR=$(grep -w "dotfiles.path" "$USER_SECRETS" | sed -n 's/.*dotfiles.path[[:space:]]*=[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)
fi
DOTFILES_DIR="${DOTFILES_DIR:-${HOME}/.dotfiles}"
SETUP_SCRIPT="${DOTFILES_DIR}/setup.sh"
FLAKE_TARGET=".#MacBook-Air"
SYSTEM_PROFILE="/nix/var/nix/profiles/system"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
NC='\033[0m'

require_cmd() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo -e "${RED}Error: Required command '$1' not found.${NC}"
        exit 1
    fi
}

run_hm() {
    if command -v home-manager >/dev/null 2>&1; then
        home-manager "$@"
    else
        echo -e "${YELLOW}--> 'home-manager' command not found. Using temporary runner via nix...${NC}"
        nix run github:nix-community/home-manager -- "$@"
    fi
}

usage() {
    echo -e "Usage: dtf [COMMAND]"
    echo -e "\nA friendly manager for your Nix dotfiles.\n"
    echo -e "Commands:"
    echo -e "  ${GREEN}a, apply${NC}        Apply the Home Manager configuration."
    echo -e "  ${GREEN}s, sync${NC}         Pull latest changes from git and then apply."
    echo -e "  ${GREEN}u, update${NC}       Update flake inputs (nixpkgs, etc.)."
    echo -e "  ${GREEN}i, init${NC}         Bootstrap Home Manager (install CLI) and apply."
    echo -e "  ${GREEN}r, rollback [N|list]${NC} Rollback to generation N, list generations, or go to previous."
    echo -e "  ${GREEN}e, edit${NC}         Open the dotfiles directory in your default editor."
    echo -e "  ${GREEN}p, push [msg]${NC}   Commit and push changes with an optional message."
    echo -e "  ${GREEN}st, status${NC}      Show the git status of the dotfiles repository."
    echo -e "  ${GREEN}gc, clean${NC}       Run Nix garbage collection to clean old generations."
    echo -e "  ${GREEN}dif, diff${NC}             Show the git difference of the dotfiles repository."
    echo -e "  ${GREEN}git [args...]${NC}   Execute git commands in the dotfiles directory."
    echo -e "  ${GREEN}gc, clean${NC}       Run Nix garbage collection to clean old generations."
    echo -e "  ${GREEN}h, help${NC}         Show this help message."
    echo
}

rollback_usage() {
    echo -e "Usage: dtf rollback [COMMAND]"
    echo -e "\nManages Home Manager generations.\n"
    echo -e "Commands:"
    echo -e "  (no arguments)     Rollback to the immediately previous generation."
    echo -e "  list               List all available generations."
    echo -e "  <generation_num>   Switch to a specific generation number."
}

cd "$DOTFILES_DIR"
require_cmd nix

if [ -z "$1" ]; then
    usage
    exit 1
fi

case "$1" in
    c|config)
        echo -e "${CYAN}--> Reconfig nix-darwin...${NC}"
        /bin/bash "$SETUP_SCRIPT"
        echo -e "${GREEN}--> Configuration complete!${NC}"
        ;;

    a|apply|switch)
        echo -e "${CYAN}--> Applying Home Manager configuration...${NC}"
        run_hm switch --flake .#default --impure
        echo -e "${GREEN}--> Configuration applied successfully! A new generation was created.${NC}"
        ;;

    s|sync)
        echo -e "${CYAN}--> Syncing repository by pulling latest changes...${NC}"
        git pull
        echo -e "\n${CYAN}--> Applying Home Manager configuration...${NC}"
        run_hm switch --flake .#default --impure
        echo -e "${GREEN}--> Sync and apply completed successfully!${NC}"
        ;;

    u|update)
        echo -e "${CYAN}--> Updating flake inputs (nixpkgs, etc.)...${NC}"
        nix flake update
        echo -e "${GREEN}--> Flake inputs updated. Run 'dtf apply' to use them.${NC}"
        ;;

    i|init|bootstrap)
        echo -e "${CYAN}--> Bootstrapping Home Manager from flake...${NC}"
        run_hm switch --flake .#default --impure
        echo -e "${GREEN}--> Bootstrap completed successfully!${NC}"
        ;;

    r|rollback)
        case "$2" in
            "") # No argument: simple rollback
                echo -e "${CYAN}--> Rolling back to the previous generation...${NC}"
                run_hm switch --rollback
                echo -e "${GREEN}--> Rollback successful!${NC}"
                ;;
            list) # List generations
                echo -e "${CYAN}--> Available Home Manager generations:${NC}"
                run_hm generations
                ;;
            *[!0-9]*) # Argument is not a number
                echo -e "${RED}Error: Invalid argument for rollback. Must be a number or 'list'.${NC}\n"
                rollback_usage
                exit 1
                ;;
            *) # Argument is a number
                echo -e "${CYAN}--> Switching to generation $2...${NC}"
                # CORRECTED COMMAND: No flake needed when switching to an existing generation
                run_hm switch --generation "$2"
                echo -e "${GREEN}--> Switched to generation $2 successfully!${NC}"
                ;;
        esac
        ;;

    e|edit)
        echo -e "${CYAN}--> Opening dotfiles in \$EDITOR (${EDITOR:-vim})...${NC}"
        ${EDITOR:-vim} .
        ;;

    p|push)
        commit_msg="${2:-"chore: update configuration"}"
        remote="${3}"
        current_branch=$(git branch --show-current)
        
        if ! git diff-index --quiet HEAD --; then
            # Has uncommitted changes, stage and commit them
            git add .
            if [ -z "$remote" ]; then
                echo -e "${CYAN}--> Committing and pushing changes to upstream...${NC}"
                git commit -m "$commit_msg"
                git push
            else
                echo -e "${CYAN}--> Committing and pushing changes to ${remote}/${current_branch}...${NC}"
                git commit -m "$commit_msg"
                git push "$remote" "$current_branch"
            fi
            echo -e "${GREEN}--> Changes pushed successfully!${NC}"
        else
            # No staged changes, check if local branch is ahead of remote
            if [ -z "$remote" ]; then
                # Use default upstream
                if git rev-parse @{u} > /dev/null 2>&1; then
                    local_commits=$(git rev-list --count @{u}..HEAD 2>/dev/null || echo "0")
                    if [ "$local_commits" -gt 0 ]; then
                        echo -e "${CYAN}--> Pushing $local_commits local commit(s) to upstream...${NC}"
                        git push
                        echo -e "${GREEN}--> Changes pushed successfully!${NC}"
                    else
                        echo -e "${YELLOW}--> Nothing to push. Local branch is up to date with remote.${NC}"
                    fi
                else
                    echo -e "${YELLOW}--> No upstream branch configured. Use: git push -u origin ${current_branch}${NC}"
                fi
            else
                # Check against specified remote
                remote_ref="${remote}/${current_branch}"
                if git rev-parse "$remote_ref" > /dev/null 2>&1; then
                    local_commits=$(git rev-list --count "${remote_ref}..HEAD" 2>/dev/null || echo "0")
                    if [ "$local_commits" -gt 0 ]; then
                        echo -e "${CYAN}--> Pushing $local_commits local commit(s) to ${remote}/${current_branch}...${NC}"
                        git push "$remote" "$current_branch"
                        echo -e "${GREEN}--> Changes pushed successfully!${NC}"
                    else
                        echo -e "${YELLOW}--> Nothing to push. Local branch is up to date with ${remote_ref}.${NC}"
                    fi
                else
                    echo -e "${CYAN}--> Creating new branch on ${remote}/${current_branch}...${NC}"
                    git push "$remote" "$current_branch"
                    echo -e "${GREEN}--> Branch pushed successfully!${NC}"
                fi
            fi
        fi
        ;;

    st|status)
        git status
        ;;
    d|dif|diff)
        git diff
        ;;
    git)
        shift
        git "$@"
        ;;
    gc|clean)
        echo -e "${CYAN}--> Cleaning up old Nix generations...${NC}"
        nix-collect-garbage -d
        echo -e "${GREEN}--> Cleanup complete.${NC}"
        ;;

    h|help|-h|--help)
        usage
        ;;

    *)
        echo -e "${RED}Error: Unknown command '$1'${NC}\n"
        usage
        exit 1
        ;;
esac